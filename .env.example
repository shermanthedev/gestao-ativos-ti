# Database (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gestao_ativos
POSTGRES_PORT=5432

# IMPORTANT: set DATABASE_URL to use the docker-compose service name `db` when running with compose
# Example: DATABASE_URL=postgresql://postgres:postgres@db:5432/gestao_ativos
DATABASE_URL=postgresql://postgres:postgres@db:5432/gestao_ativos

# Server
JWT_SECRET=replace-this-secret
SERVER_PORT=3333

# Client
CLIENT_PORT=5173

# Notes:
# - Copy this file to .env and fill values before running `docker-compose up`.
# - When not using docker, set DATABASE_URL to the external DB address.
